# Database - use with docker-compose postgres for local dev
DATABASE_URL="postgresql://elasticos:elasticos_dev@localhost:5432/elastic_os"

# Railway PostgreSQL - Railway injects DATABASE_URL when Postgres is added to the project
# For local connections to Railway DB use DATABASE_PUBLIC_URL (provided in Railway dashboard)
# DATABASE_PUBLIC_URL="postgresql://..."

# NextAuth - set NEXTAUTH_URL to your deployment URL (e.g. https://your-app.railway.app)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Resend (contact form emails to info@francescatabor.com)
RESEND_API_KEY="re_xxx"
# Optional: custom from address (must be verified domain). Default: onboarding@resend.dev
# RESEND_FROM_EMAIL="ElasticOS <noreply@yourdomain.com>"
